# ==============================================================================
# WASTEWISE ENTERPRISE FRONTEND - ENVIRONMENT VARIABLES
# ==============================================================================

# ── LOCAL DEVELOPMENT ─────────────────────────────────────────────────────────
# When running the frontend locally (npm run dev), Next.js will automatically
# load this URL to connect to your local backend.
# NOTE: To use this locally, run: cp .env.example .env.local
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── PRODUCTION (VERCEL) ───────────────────────────────────────────────────────
# DO NOT commit your production URL here! 
# Instead, go to your Vercel Dashboard -> Settings -> Environment Variables,
# and add NEXT_PUBLIC_API_URL = https://your-backend-url.hf.space
