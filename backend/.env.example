# ==============================================================================
# WASTEWISE ENTERPRISE BACKEND - ENVIRONMENT VARIABLES
# ==============================================================================

# ── MANDATORY SYSTEM SECURITY ─────────────────────────────────────────────────
# Generated via: cd backend && python keygen.py
SECRET_KEY=your_secure_random_key_here

# Used to verify incoming requests from Telegram (prevent spoofing).
WEBHOOK_SECRET=your_secure_random_password

# The exact URL of your deployed frontend (e.g., https://your-app.vercel.app).
# Prevents unauthorized websites from calling your backend API. Multiple origins can be comma-separated.
ALLOWED_ORIGINS=http://localhost:3000

# Primary admin email for system alerts and root access
ADMIN_EMAIL=admin@yourcompany.com


# ── TELEGRAM BOT INTEGRATION ──────────────────────────────────────────────────
# From @BotFather on Telegram (Required)
TELEGRAM_TOKEN=your_telegram_bot_token_here

# The exact username of your bot (e.g., WasteWise_Bot)
BOT_USERNAME=your_bot_username_here


# ── AI PROVIDERS (At least Gemini is required) ────────────────────────────────
# Primary AI for Forecasting, Causal Inference, and Computer Vision
GEMINI_API_KEY=your_gemini_api_key_here

# Fallback AI for faster NLP classification
GROQ_API_KEY=your_groq_api_key_here

# Secondary fallback AI
MISTRAL_API_KEY=your_mistral_api_key_here


# ── HYBRID DATABASE LAYER (Supabase + Redis) ──────────────────────────────────
# Required for production persistence across restarts
SUPABASE_URL=your_supabase_project_url
SUPABASE_SERVICE_KEY=your_supabase_service_role_key

# Required for instant in-memory caching and session state
REDIS_URL=your_upstash_redis_url_here


# ── LOCATION & WEATHER SERVICES ───────────────────────────────────────────────
# Used for geocoding and foot-traffic analytics
LOCATIONIQ_API_KEY=your_locationiq_api_key_here
GEOAPIFY_API_KEY=your_geoapify_api_key_here


# ── COMMUNICATIONS & EMAIL ────────────────────────────────────────────────────
# Required for sending OTP login codes to dashboard users
RESEND_API_KEY=your_resend_api_key_here
FROM_EMAIL=onboarding@resend.dev


# ── BACKGROUND TASK WORKERS (Celery) ──────────────────────────────────────────
# NOTE: If using Upstash Redis FREE TIER, you only get one database index (/0).
# In that case, both Broker and Result Backend MUST end in /0. 
# If you upgrade to a paid Redis instance, change the Result Backend to /1.
CELERY_BROKER_URL=redis://your_broker_url_here:6379/0
CELERY_RESULT_BACKEND=redis://your_result_backend_here:6379/0
